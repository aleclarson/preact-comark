{
  "include": ["src"],
  "compilerOptions": {
    "strict": true,
    "erasableSyntaxOnly": true,
    "noUncheckedSideEffectImports": true,
    "lib": ["esnext", "DOM", "DOM.Iterable"],
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "declaration": true,
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    "types": []
  }
}
